@page "/"
@page "/login"
@layout AdminLayout
@inject IAdminAuthService Auth
@inject NavigationManager Nav

<div class="login-page">
    <div class="login-card">
        <h1 class="login-title">IM 系统管理后台</h1>
        <p class="login-subtitle">管理员登录</p>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="login-error">@_error</div>
        }

        <div class="login-form">
            <div class="form-group">
                <label>管理员账号</label>
                <input @bind="_username" placeholder="admin" />
            </div>
            <div class="form-group">
                <label>密码</label>
                <input type="password" @bind="_password" placeholder="admin123" />
            </div>
            <button class="btn btn-primary" style="width:100%;padding:12px;margin-top:8px;" @onclick="DoLogin">登录</button>
        </div>
        <p style="text-align:center;font-size:11px;color:#999;margin-top:16px;">测试账号：admin / admin123</p>
    </div>
</div>

@code {
    private string _username = "";
    private string _password = "";
    private string? _error;

    protected override void OnInitialized()
    {
        if (Auth.IsLoggedIn)
            Nav.NavigateTo("/review");
    }

    private void DoLogin()
    {
        if (Auth.Login(_username, _password))
            Nav.NavigateTo("/review");
        else
            _error = "账号或密码错误";
    }
}
