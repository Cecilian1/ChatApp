@page "/"
@page "/login"
@inject IUserAuthService Auth
@inject NavigationManager Nav

<div class="auth-page">
    <div class="auth-card">
        <h1 class="auth-title">网上沟通交流系统</h1>
        <p class="auth-subtitle">桌面客户端登录</p>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-error">@_error</div>
        }

        <div class="login-form">
            <div class="form-group">
                <label>账号</label>
                <input @bind="_username" @bind:event="oninput" placeholder="请输入账号" />
            </div>
            <div class="form-group">
                <label>密码</label>
                <input type="password" @bind="_password" @bind:event="oninput" placeholder="请输入密码" />
            </div>
            <button class="auth-btn" disabled="@_loading" @onclick="DoLogin">
                @(_loading ? "登录中..." : "登录")
            </button>
        </div>

        <p class="auth-link">没有账号？<a href="/register">注册申请</a></p>
    </div>
</div>

@code {
    private string _username = "";
    private string _password = "";
    private string? _error;
    private bool _loading;

    private async Task DoLogin()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(_username) || string.IsNullOrWhiteSpace(_password))
        {
            _error = "请输入账号和密码";
            return;
        }

        _loading = true;
        try
        {
            if (await Auth.LoginAsync(_username.Trim(), _password))
                Nav.NavigateTo("/chat");
            else
                _error = "账号或密码错误";
        }
        finally
        {
            _loading = false;
        }
    }
}
