@model ChatApp.Shared.Models.MessageDto
@{
    var side = Model.IsMine ? "message-right" : "message-left";
    var apiBase = ViewBag.ApiBaseUrl as string ?? "http://localhost:5200";
    var avatarUrl = ChatApp.Shared.Utils.AvatarUrls.GetSvgUrl(apiBase, Model.SenderAvatarSeed);
    var isGroup = !Model.IsMine;

    string FormatFileSize(long? bytes)
    {
        if (!bytes.HasValue) return "";
        if (bytes.Value < 1024) return bytes.Value + " B";
        if (bytes.Value < 1024 * 1024) return (bytes.Value / 1024.0).ToString("F1") + " KB";
        return (bytes.Value / (1024.0 * 1024)).ToString("F1") + " MB";
    }
}

<div class="message-wrapper @side" data-message-id="@Model.Id">
    <img src="@avatarUrl" alt="头像" class="avatar-sm" />
    <div class="message-content">
        @if (isGroup && !Model.IsMine)
        {
            <span class="sender-name">@Model.SenderName</span>
        }
        @if (Model.Type == ChatApp.Shared.Enums.MessageType.File)
        {
            var fileUrl = Model.Content;
            if (!string.IsNullOrEmpty(fileUrl) && !fileUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase))
            {
                fileUrl = $"{Context.Request.Scheme}://{Context.Request.Host}{fileUrl}";
            }
            var fileSizeText = FormatFileSize(Model.FileSize);
            <div class="file-card">
                <div class="file-icon">📄</div>
                <div class="file-info">
                    <a href="@fileUrl" target="_blank" class="file-name" download>@(Model.FileName ?? "文件")</a>
                    @if (!string.IsNullOrEmpty(fileSizeText))
                    {
                        <span class="file-size"> (@fileSizeText)</span>
                    }
                    @if (Model.FileProgress.HasValue && Model.FileProgress < 100)
                    {
                        <div class="progress-bar"><div class="progress" style="width:@(Model.FileProgress)%"></div></div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="msg-bubble">@Model.Content</div>
        }
    </div>
</div>
