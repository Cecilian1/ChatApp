@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>登录 - 网上沟通交流系统</title>
    <link rel="stylesheet" href="~/css/user.css" />
</head>
<body class="auth-page">
<div class="auth-card">
    <h1 class="auth-title">网上沟通交流系统</h1>
    <p class="auth-subtitle">用户登录</p>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-error">@ViewBag.Error</div>
    }

    <form method="post" asp-action="Login">
        <div class="form-group">
            <label>账号</label>
            <input type="text" name="username" placeholder="请输入账号" required />
        </div>
        <div class="form-group">
            <label>密码</label>
            <input type="password" name="password" placeholder="请输入密码" required />
        </div>
        <button type="submit" class="auth-btn">登录</button>
    </form>

    <p class="auth-link">还没有账号？<a asp-action="Register">注册申请</a></p>
</div>
</body>
</html>
